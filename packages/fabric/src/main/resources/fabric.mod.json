{
  "schemaVersion": 1,
  "id": "sharedworld",
  "version": "${version}",
  "name": "SharedWorld",
  "description": "Cloud-backed friend-hosted Minecraft worlds powered by e4mc.",
  "authors": [
    "Bolido"
  ],
  "icon": "share_world_pixel_art.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "link.sharedworld.SharedWorldClient"
    ]
  },
  "mixins": [
    "sharedworld.mixins.json",
    "sharedworld-versioned.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loaderVersion}",
    "minecraft": "${minecraftRange}",
    "java": ">=${javaVersion}",
    "fabric-api": "*",
    "e4mc": ">=6.0.6 <7.0.0"
  }
}
